Kesimpulan dan Key Insights","metadata":{}},{"cell_type":"markdown","source":"### 9.1 Ringkasan Temuan Utama","metadata":{}},{"cell_type":"code","source":"print(\"=\"*100)\nprint(\"                          KEY INSIGHTS & KESIMPULAN\")\nprint(\"=\"*100)\n\nprint(\"\\n🎯 TEMUAN UTAMA UPAH MINIMUM PROVINSI (UMP):\")\nprint(\"-\" * 100)\n\n# 1. Pertumbuhan UMP\nfirst_year_ump = df_ump[df_ump['tahun'] == 2002]['ump'].mean()\nlast_year_ump = df_ump[df_ump['tahun'] == 2020]['ump'].mean()\ntotal_growth_ump = ((last_year_ump / first_year_ump) - 1) * 100\navg_annual_growth = (((last_year_ump / first_year_ump) ** (1/18)) - 1) * 100\n\nprint(f\"1. UMP rata-rata nasional meningkat dari Rp {first_year_ump:,.0f} (2002) menjadi \")\nprint(f\"   Rp {last_year_ump:,.0f} (2020), atau tumbuh {total_growth_ump:.1f}% dalam 18 tahun.\")\nprint(f\"   Rata-rata pertumbuhan tahunan (CAGR): {avg_annual_growth:.2f}%\")\n\n# 2. Kesenjangan regional\nump_2020 = df_ump[df_ump['tahun'] == 2020]\nhighest_ump = ump_2020.loc[ump_2020['ump'].idxmax()]\nlowest_ump = ump_2020.loc[ump_2020['ump'].idxmin()]\ngap = highest_ump['ump'] - lowest_ump['ump']\n\nprint(f\"\\n2. Kesenjangan UMP antar provinsi (2020):\")\nprint(f\"   • Tertinggi: {highest_ump['provinsi']} (Rp {highest_ump['ump']:,.0f})\")\nprint(f\"   • Terendah: {lowest_ump['provinsi']} (Rp {lowest_ump['ump']:,.0f})\")\nprint(f\"   • Selisih: Rp {gap:,.0f} ({(gap/lowest_ump['ump']*100):.1f}% dari yang terendah)\")\n\n# 3. Provinsi top performer\nprint(f\"\\n3. Top 3 provinsi dengan UMP tertinggi (2020):\")\ntop_3 = ump_2020.nlargest(3, 'ump')\nfor i, (idx, row) in enumerate(top_3.iterrows(), 1):\n    print(f\"   {i}. {row['provinsi']}: Rp {row['ump']:,.0f}\")\n\nprint(\"\\n\" + \"=\"*100)\nprint(\"\\n🎯 TEMUAN UTAMA RATA-RATA UPAH:\")\nprint(\"-\" * 100)\n\n# 4. Tren upah\nupah_2015 = df_upah[df_upah['tahun'] == 2015]['upah'].mean()\nupah_2022 = df_upah[df_upah['tahun'] == 2022]['upah'].mean()\ngrowth_upah = ((upah_2022 / upah_2015) - 1) * 100\n\np