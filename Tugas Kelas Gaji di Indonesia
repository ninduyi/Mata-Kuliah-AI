=5, capthick=2)\n\nax.set_xlabel('Tahun', fontsize=14, fontweight='bold')\nax.set_ylabel('Upah (Rupiah)', fontsize=14, fontweight='bold')\nax.set_title('Tren Rata-Rata Upah di Indonesia (2015-2022)', fontsize=16, fontweight='bold', pad=20)\nax.legend(fontsize=12)\nax.grid(True, alpha=0.3, linestyle='--')\nax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'Rp {x:,.0f}'))\n\n# Tambahkan anotasi untuk tahun awal dan akhir\nfor i in [0, -1]:\n    row = upah_yearly.iloc[i]\n    ax.annotate(f\"Rp {row['mean']:,.0f}\", \n               xy=(row['tahun'], row['mean']), \n               xytext=(10, 10), textcoords='offset points',\n               fontsize=11, fontweight='bold',\n               bbox=dict(boxstyle='round,pad=0.5', facecolor='yellow', alpha=0.7))\n\nplt.tight_layout()\nplt.show()\n\n# Tampilkan tabel\nprint(\"\\n📊 Tabel Evolusi Rata-Rata Upah Tahunan:\")\nupah_yearly_display = upah_yearly.copy()\nfor col in ['mean', 'median', 'std', 'min', 'max']:\n    upah_yearly_display[col] = upah_yearly_display[col].apply(lambda x: f'Rp {x:,.0f}')\ndisplay(upah_yearly_display)","metadata":{"execution":{"iopub.status.busy":"2026-04-06T00:59:57.934876Z","iopub.execute_input":"2026-04-06T00:59:57.935175Z","iopub.status.idle":"2026-04-06T00:59:58.268691Z","shell.execute_reply.started":"2026-04-06T00:59:57.935148Z","shell.execute_reply":"2026-04-06T00:59:58.267957Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x800 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n📊 Tabel Evolusi Rata-Rata Upah Tahunan:\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"   tahun       mean     median       std        min        max\n0   2015  Rp 12,929  Rp 12,660  Rp 2,656   Rp 8,525  Rp 19,290\n1   2016  Rp 15,086  Rp 14,068  Rp 3,673   Rp 9,940  Rp 23,444\n2   2017  Rp 15,670  Rp 14,822  Rp 3,568  Rp 10,569  Rp 25,657\n3   2018  Rp 15,893  Rp 15,275  Rp 3,834  Rp 11,359  Rp 25,987\