['tahun'], rasio_yearly['mean'], marker='o', linewidth=3, \n         label='Rata-rata Rasio', color='#2E86AB', markersize=10)\nax1.plot(rasio_yearly['tahun'], rasio_yearly['median'], marker='s', linewidth=3, \n         label='Median Rasio', color='#A23B72', markersize=10)\nax1.fill_between(rasio_yearly['tahun'], \n                 rasio_yearly['mean'] - rasio_yearly['std'],\n                 rasio_yearly['mean'] + rasio_yearly['std'],\n                 alpha=0.2, color='#2E86AB', label='±1 Std Dev')\nax1.axhline(y=100, color='red', linestyle='--', linewidth=2, label='100% (Upah = UMP)')\nax1.set_xlabel('Tahun', fontsize=12, fontweight='bold')\nax1.set_ylabel('Rasio Upah/UMP (%)', fontsize=12, fontweight='bold')\nax1.set_title('Tren Rasio Rata-Rata Upah terhadap UMP (2015-2020)', fontsize=14, fontweight='bold', pad=15)\nax1.legend(fontsize=11)\nax1.grid(True, alpha=0.3)\n\n# Plot 2: Distribusi rasio per provinsi (2020)\nrasio_2020 = df_merged[df_merged['tahun'] == 2020].sort_values('rasio_upah_ump', ascending=False)\n\ncolors_rasio = ['green' if x >= 100 else 'red' for x in rasio_2020['rasio_upah_ump']]\nbars = ax2.barh(range(len(rasio_2020)), rasio_2020['rasio_upah_ump'], \n                color=colors_rasio, alpha=0.7, edgecolor='black')\nax2.set_yticks(range(len(rasio_2020)))\nax2.set_yticklabels(rasio_2020['provinsi'], fontsize=9)\nax2.axvline(x=100, color='black', linestyle='--', linewidth=2, label='100% (Upah = UMP)')\nax2.set_xlabel('Rasio Upah/UMP (%)', fontsize=12, fontweight='bold')\nax2.set_title('Rasio Rata-Rata Upah terhadap UMP per Provinsi (2020)', fontsize=14, fontweight='bold', pad=15)\nax2.legend(fontsize=10)\nax2.grid(True, alpha=0.3, axis='x')\n\n# Tambahkan nilai di ujung bar\nfor bar, val in zip(bars, rasio_2020['rasio_upah_ump']):\n    ax2.text(val, bar.get_y() + bar.get_height()/2, f'{val:.1f}%', \n             va='center', ha='left' if val < 100 else 'right', \n             fontsize=8, fontweight='bold')\n\nplt.tight_layout()\nplt.show()\n\n# Insight\nprint(\"\\n📊 Analisis Rasio Upah/UMP (2020):\")\nprint(\"=\"*80)\nabove_ump = len(rasio_2020[rasio_2020['rasio_upah_ump'] >= 100])\nbelow_ump = len(rasio_2020[rasio_2020['rasio_upah_ump'] < 100])\nprint(f\"✓ Provinsi dengan upah ≥ UMP: {above_ump}\")\nprint(f\"✓ Provinsi dengan upah < UMP: {below_ump}\")\nprint(f\"✓ Rata-rata rasio: {rasio_2020['rasio_upah_ump'].mean():.2f}%\")\nprint(f\"✓ Provinsi dengan rasio tertinggi: {rasio_2020.iloc[0]['provinsi']} ({rasio_2020.iloc[0]['rasio_upah_ump']:.2f}%)\")\nprint(f\"✓ Provinsi dengan rasio terendah: {rasio_2020.iloc[-1]['provinsi']} ({rasio_2020.iloc[-1]['rasio_upah_ump']:.2f}%)\")","metadata":{"execution":{"iopub.status.busy":"2026-04-06T00:59:58.790928Z","iopub.execute_input":"2026-04-06T00:59:58.791304Z","iopub.status.idle":"2026-04-06T00:59:59.724448Z","shell.execute_reply.started":"2026-04-06T00:59:58.791267Z","shell.execute_reply":"2026-04-06T00:59:59.723469Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x1200 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n📊 Analisis Rasio Upah/UMP (2020):\n================================================================================\n✓ Provinsi dengan upah ≥ UMP: 0\n✓ Provinsi dengan upah < UMP: 35\n✓ Rata-rata rasio: 0.74%\n✓ Provinsi dengan rasio tertinggi: JAWA BARAT (1.05%)\n✓ Provinsi dengan rasio terendah: KEP. BANGKA BELITUNG (0.49%)\n","output_type":"stream"}],"execution_count":20},{"cell_type":"markdown","source":"**Interpretasi rasio upah terhadap UMP**\n\nOutput menunjukkan seluruh provinsi memiliki rasio jauh di bawah 100%, bahkan rata-ratanya hanya sekitar **0,74%**. Secara substantif, angka ini **tidak realistis** jika dibaca secara literal. Karena itu, hasil ini justru menjadi indikator kuat bahwa terdapat **perbedaan satuan atau definisi pengukuran** antara variabel `upah` dan `ump`.\n\nKesimpulan pentingnya bukan bahwa semua provinsi “melanggar UMP”, melainkan bahwa **rasio ini tidak layak dipakai untuk menilai kepatuhan** sebelum satuan datanya dinormalisasi terlebih dahulu. Temuan ini tetap bernilai karena menunjukkan adanya isu kualitas/kompatibilitas data yang harus dibereskan.\n","metadata":{}},{"cell_type":"markdown","source":"### 7.3 Scatter Plot: UMP vs Rata-Rata Upah (2020)","metadata":{}},{"cell_type":"code","source":"# Data untuk scatter plot\ndata_2020 = df_merged[df_merged['tahun'] == 2020]\n\n# Visualisasi\nfig, ax = plt.subplots(figsize=(14, 10))\n\n# Scatter plot\nscatter = ax.scatter(data_2020['ump'], data_2020['upah'], \n                    s=200, alpha=0.6, c=data_2020['rasio_upah_ump'], \n                    cmap='RdYlGn', edgecolors='black', linewidth=1.5)\n\n# Tambahkan colorbar\ncbar = plt.colorbar(scatter, ax=ax)\ncbar.set_label('Rasio Upah/UMP (%)', fontsize=12, fontweight='bold')\n\n# Tambahkan garis y=x (upah = ump)\nmax_val = max(data_2020['ump'].max(), data_2020['upah'].max())\nmin_val = min(data_2020['ump'].min(), data_2020['upah'].min())\nax.plot([min_val, max_val], [min_val, max_val], 'r--', linewidth=2, \n        label='Upah = UMP', alpha=0.7)\n\n# Label untuk beberapa provinsi penting\nimportant_provinces = ['DKI JAKARTA', 'PAPUA', 'JAWA BARAT', 'JAWA TIMUR']\nfor _, row in data_2020.iterrows():\n    if row['provinsi'] in important_provinces:\n        ax.annotate(row['provinsi'], xy=(row['ump'], row['upah']), \n                   xytext=(10, 10), textcoords='offset points',\n                   fontsize=9, fontweight='bold',\n                   bbox=dict(boxstyle='round,pad=0.3', facecolor='yellow', alpha=0.7),\n                   arrowprops=dict(arrowstyle='->', connectionstyle='arc3,rad=0'))\n\nax.set_xlabel('UMP (Rupiah)', fontsize=14, fontweight='bold')\nax.set_ylabel('Rata-rata Upah (Rupiah)', fontsize=14, fontweight='bold')\nax.set_title('Hubungan UMP vs Rata-Rata Upah per Provinsi (2020)', fontsize=16, fontweight='bold', pad=20)\nax.legend(fontsize=12)\nax.grid(True, alpha=0.3)\nax.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'Rp {x/1e6:.1f}M'))\nax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'Rp {x:,.0f}'))\n\nplt.tight_layout()\nplt.show()\n\n# Hitung korelasi\ncorrelation = data_2020['ump'].corr(data_2020['upah'])\nprint(f\"\\n📊 Korelasi antara UMP dan Rata-Rata Upah (2020): {correlation:.4f}\")\nif correlation > 0.7:\n    print(\"   → Korelasi positif kuat\")\nelif correlation > 0.4:\n    print(\"   → Korelasi positif sedang\")\nelse:\n    print(\"   → Korelasi lemah\")","metadata":{"execution":{"iopub.status.busy":"2026-04-06T00:59:59.725785Z","iopub.execute_input":"2026-04-06T00:59:59.726192Z","iopub.status.idle":"2026-04-06T01:00:00.287053Z","shell.execute_reply.started":"2026-04-06T00:59:59.726150Z","shell.execute_reply":"2026-04-06T01:00:00.285997Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x1000 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n📊 Korelasi antara UMP dan Rata-Rata Upah (2020): 0.6181\n   → Korelasi positif sedang\n","output_type":"stream"}],"execution_count":21},{"cell_type":"markdown","source":"**Interpretasi scatter plot dan korelasi**\n\nNilai korelasi sekitar **0,62** menunjukkan hubungan positif tingkat sedang antara UMP dan rata-rata upah. Artinya, **provinsi dengan UMP lebih tinggi cenderung juga memiliki rata-rata upah yang lebih tinggi**, meskipun hubungan tersebut tidak sempurna.\n\nSecara ekonomi, hal ini masuk akal: daerah dengan struktur ekonomi lebih maju atau biaya hidup lebih mahal biasanya menetapkan UMP lebih tinggi dan juga memiliki tingkat upah rata-rata lebih besar. Namun sekali lagi, karena ada indikasi perbedaan satuan, grafik ini lebih tepat dibaca sebagai **hubungan arah dan pola**, bukan perbandingan level absolut.\n","metadata":{}},{"cell_type":"markdown","source":"## 8. Analisis Regional","metadata":{}},{"cell_type":"markdown","source":"### 8.1 Pengelompokan Provinsi berdasarkan Pulau/Region","meta