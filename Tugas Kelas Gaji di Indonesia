pah'])):\n    ax1.text(val, bar.get_y() + bar.get_height()/2, f'Rp {val:,.0f}', \n             va='center', ha='left', fontsize=9, fontweight='bold', color='darkblue')\n\n# Bottom 10\nbars2 = ax2.barh(range(len(bottom_10_upah)), bottom_10_upah['upah'], color='#F18F01', edgecolor='black')\nax2.set_yticks(range(len(bottom_10_upah)))\nax2.set_yticklabels(bottom_10_upah['provinsi'], fontsize=10)\nax2.invert_yaxis()\nax2.set_xlabel('Rata-rata Upah (Rupiah)', fontsize=12, fontweight='bold')\nax2.set_title('10 Provinsi dengan Rata-Rata Upah Terendah (2022)', fontsize=13, fontweight='bold', pad=15)\nax2.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'Rp {x:,.0f}'))\nax2.grid(True, alpha=0.3, axis='x')\n\nfor i, (bar, val) in enumerate(zip(bars2, bottom_10_upah['upah'])):\n    ax2.text(val, bar.get_y() + bar.get_height()/2, f'Rp {val:,.0f}', \n             va='center', ha='left', fontsize=9, fontweight='bold', color='darkorange')\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n📊 Top 10 Provinsi Rata-Rata Upah Tertinggi (2022):\")\ntop_10_upah_display = top_10_upah[['provinsi', 'upah']].copy()\ntop_10_upah_display['upah'] = top_10_upah_display['upah'].apply(lambda x: f'Rp {x:,.0f}')\ntop_10_upah_display.index = range(1, len(top_10_upah_display) + 1)\ndisplay(top_10_upah_display)","metadata":{"execution":{"iopub.status.busy":"2026-04-06T00:59:58.271488Z","iopub.execute_input":"2026-04-06T00:59:58.271768Z","iopub.status.idle":"2026-04-06T00:59:58.765867Z","shell.execute_reply.started":"2026-04-06T00:59:58.271743Z","shell.execute_reply":"2026-04-06T00:59:58.765019Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x800 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n📊 Top 10 Provinsi Rata-Rata Upah Tertinggi (2022):\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"              provinsi       upah\n1          DKI JAKARTA  Rp 32,685\n2          PAPUA BARAT  Rp 24,128